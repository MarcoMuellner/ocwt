{
  "name": "opencode-ocwt",
  "version": "0.1.0",
  "description": "OpenCode plugin for native ocwt worktree workflows",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.24"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.24",
    "@types/node": "^22.13.10",
    "oxlint": "^0.15.12",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
