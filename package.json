{
  "name": "opencode-ocwt",
  "version": "0.4.5",
  "description": "OpenCode plugin for native ocwt worktree workflows",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarcoMuellner/ocwt.git"
  },
  "homepage": "https://github.com/MarcoMuellner/ocwt#readme",
  "bugs": {
    "url": "https://github.com/MarcoMuellner/ocwt/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "git-worktree",
    "worktree",
    "ocwt"
  ],
  "packageManager": "pnpm@10.28.1",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm format:check",
    "pack:dry-run": "npm pack --dry-run",
    "version:nightly": "node ./scripts/prepare-nightly-version.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.24",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.24"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.24",
    "@types/node": "^22.13.10",
    "oxlint": "^0.15.12",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
